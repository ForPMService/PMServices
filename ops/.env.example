# =========================
# PMServices Local Dev Env
# =========================

# --- API ---
API_HTTP_PORT=8080

# --- App Postgres ---
APP_DB_PORT=5432
APP_DB_PASSWORD=pmservices_dev_password

# --- Keycloak Postgres ---
KC_DB_PORT=5433
KC_DB_PASSWORD=keycloak_dev_password

# --- Keycloak ---
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=pmservices
KEYCLOAK_CLIENT_ID=pmservices-api
KEYCLOAK_CLIENT_SECRET=change_me

# Внутренний URL (контейнер -> контейнер)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Публичный URL (браузер пользователя)
KEYCLOAK_PUBLIC_URL=http://localhost:8081

# --- Redis ---
REDIS_PORT=6379

# --- Mailpit ---
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025