# PMServices Docker Environment
# Скопировать в .env и заполнить значения
# НИКОГДА не коммитить .env с реальными паролями!

# ─────────────────────────────────────────────
# PostgreSQL (root для init)
# ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# Application Database
# ─────────────────────────────────────────────
APP_DB=pmservices
APP_USER=pmservices
APP_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# Keycloak Database
# ─────────────────────────────────────────────
KC_DB=keycloak
KC_USER=keycloak
KC_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────
# Keycloak Admin
# ─────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
